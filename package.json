{
  "name": "excalidraw",
  "private": true,
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:turbo": "turbo run build",
    "dev": "pnpm --parallel --stream --filter web --filter http-backend --filter ws-backend run dev",
    "dev:turbo": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:http": "pnpm --filter http-backend dev",
    "dev:ws": "pnpm --filter ws-backend dev",
    "lint": "pnpm -r --if-present lint",
    "lint:turbo": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "pnpm -r --if-present check-types",
    "check-types:turbo": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
